
# URL de conexão do Prisma com o banco PostgreSQL
DATABASE_URL=postgresql://<seu_usuario>:<sua_senha>@postgresql:5432/<seu_banco_de_dados>?schema=public

# Nome do banco de dados PostgreSQL
POSTGRES_DB=<seu_banco_de_dados>
# Usuário do banco de dados PostgreSQL
POSTGRES_USER=<seu_usuario>
# Senha do banco de dados PostgreSQL
POSTGRES_PASSWORD=<sua_senha>

# Porta em que a aplicação Express irá rodar
API_PORT=6060

# Níveis de log emitidos pelo Prisma (opcional). Valores válidos: query,info,warn,error
PRISMA_LOG_LEVELS=warn,error

# Ambiente da aplicação (development, production, test)
NODE_ENV=development

# Ativa/desativa logs no terminal (true/false)
LOG_CONSOLE_ENABLED=true

# Tamanho máximo total dos arquivos de log (em GB)
LOG_MAX_SIZE_GB=1

# Nível mínimo dos logs (error, warn, info, debug)
LOG_LEVEL=debug

# BetterAuth - Chave secreta para criptografia (mínimo 32 caracteres)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=<sua_chave_secreta_aqui>

# BetterAuth - URL base da API
BETTER_AUTH_URL=http://localhost:6060
